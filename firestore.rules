rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Orders collection
    match /orders/{orderId} {
      // Anyone can create orders (from checkout)
      allow create: if true;
      
      // Only authenticated admins can read, update, delete
      allow read, update, delete: if request.auth != null;
    }
    
    // Customers collection
    match /customers/{customerId} {
      // Allow create/update/read if true to enable checkout and admin sync
      // Ideally read should be restricted, but for MVP we need to be practical
      allow read, write: if true;
    }
    
    // Products collection (future)
    match /products/{productId} {
      // Anyone can read products (for storefront)
      allow read: if true;
      
      // Only authenticated admins can write
      allow write: if request.auth != null;
    }
    
    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
